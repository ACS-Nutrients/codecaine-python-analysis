# Analysis Service 환경변수 예시
# cp .env.example .env 후 실제 값으로 채울 것

# ── Database ──────────────────────────────────────────────────────────────────
# [필수] PostgreSQL — vitamin_analysis DB
DATABASE_URL=postgresql://vitamin_analysis:<password>@<host>:5432/vitamin_analysis

# ── AWS 공통 ──────────────────────────────────────────────────────────────────
AWS_REGION=ap-northeast-2

# ── S3 — CODEF 원본 데이터 저장 (선택) ───────────────────────────────────────
# 미설정 시 S3 저장을 건너뜀. API 응답 자체는 정상 동작함
S3_BUCKET_NAME=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── CODEF — 국민건강보험 건강검진 연동 (필수) ─────────────────────────────────
# https://developer.codef.io 에서 애플리케이션 등록 후 발급
CODEF_CLIENT_ID=
CODEF_CLIENT_SECRET=

# ── AWS Bedrock Agent — 영양소 분석 AI (선택) ─────────────────────────────────
# 미설정(placeholder) 시 mock 응답 반환
BEDROCK_AGENT_ID=
BEDROCK_AGENT_ALIAS_ID=
