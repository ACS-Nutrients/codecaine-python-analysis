# Analysis Service 환경변수 예시
# cp .env.example .env 후 실제 값으로 채울 것

# ── Database ──────────────────────────────────────────────────────────────────
# [필수] PostgreSQL — vitamin_analysis DB
DATABASE_URL=postgresql://vitamin_analysis:<password>@<host>:5432/vitamin_analysis

# ── AWS 공통 ──────────────────────────────────────────────────────────────────
AWS_REGION=ap-northeast-2

# ── AWS Bedrock Agent — 영양소 분석 AI (선택) ─────────────────────────────────
# 미설정(placeholder) 시 mock 응답 반환
BEDROCK_AGENT_ID=
BEDROCK_AGENT_ALIAS_ID=

# ── Analysis Lambda — 직접 호출 (필수) ────────────────────────────────────────
# aws lambda get-function --function-name analysis-agent \
#   --query 'Configuration.FunctionArn' --output text
ANALYSIS_LAMBDA_ARN=arn:aws:lambda:ap-northeast-2:<ACCOUNT_ID>:function:analysis-agent

# IAM 자격증명 (ECS Task Role 사용 시 비워둬도 됨)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── AWS Cognito — JWT 인증 (필수) ─────────────────────────────────────────────
COGNITO_USER_POOL_ID=ap-northeast-2_XXXXXXXXX
COGNITO_REGION=ap-northeast-2
