# Analysis Service 환경변수 예시
# cp .env.example .env 후 실제 값으로 채울 것

# ── Database ──────────────────────────────────────────────────────────────────
# [필수] PostgreSQL — vitamin_analysis DB
DATABASE_URL=postgresql://vitamin_analysis:<password>@<host>:5432/vitamin_analysis

# ── AWS 공통 ──────────────────────────────────────────────────────────────────
AWS_REGION=ap-northeast-2

# ── AgentCore Runtime — 영양소 분석 AI (필수) ─────────────────────────────────
# 미설정(placeholder) 시 mock 응답 반환
AGENTCORE_RUNTIME_ARN=arn:aws:bedrock-agentcore:ap-northeast-2:070238434919:runtime/analysis_agent-bA2YOVDhUj

# IAM 자격증명 (ECS Task Role 사용 시 비워둬도 됨)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── AWS Cognito — JWT 인증 (필수) ─────────────────────────────────────────────
COGNITO_USER_POOL_ID=ap-northeast-2_XXXXXXXXX
COGNITO_REGION=ap-northeast-2
